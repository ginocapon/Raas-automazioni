# Abilita rewrite
RewriteEngine On

# STEP 1: REDIRECT .html -> URL PULITI (301)
# /bandi.html -> /bandi
# /blog.html -> /blog  
# /pagina.html -> /pagina
RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# STEP 2: INTERNAMENTE SERVE IL FILE .html
# /bandi -> serve bandi.html
# /blog -> serve blog.html
# /pagina -> serve pagina.html se esiste
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+)$ $1.html [L]
